
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= title %></title>
  <style>
    body { margin:0; font-family:Arial,sans-serif; background:var(--background); color:var(--foreground); }
    .container {
      max-width:500px;
      margin:40px auto;
      background:var(--card);
      padding:20px;
      border-radius:var(--radius);
      box-shadow:0 2px 8px rgba(0,0,0,0.1);
      border:1px solid var(--border);
    }
    h2 { text-align:center; margin-bottom:20px; }
    label { display:block; margin:10px 0 5px; font-weight:bold; }
    input, select, textarea {
      width:100%;
      padding:8px;
      border:1px solid var(--input);
      border-radius:var(--radius);
      box-sizing: border-box;
    }
    .button-group {
      display: flex;
      gap: 15px;
      margin-top: 20px;
    }
    .btn {
      flex: 1;
      padding: 10px;
      border: none;
      border-radius: var(--radius);
      font-size: 16px;
      cursor: pointer;
      text-align: center;
      text-decoration: none;
      font-weight: bold;
    }
    .btn-apply {
      background: var(--primary);
      color: var(--primary-foreground);
    }
    .btn-apply:hover {
      background: var(--destructive);
    }
    .btn-cancel {
      background: var(--secondary);
      color: var(--secondary-foreground);
      border: 1px solid var(--border);
    }
    .btn-cancel:hover {
      background: var(--muted);
    }
    .image-list {
      display: grid;
      gap: 10px;
      margin-top: 10px;
    }
    .image-row {
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .image-row img {
      width: 72px;
      height: 54px;
      object-fit: cover;
      border-radius: var(--radius);
      border: 1px solid var(--border);
    }
    .image-row form {
      margin: 0;
    }
    .btn-small {
      padding: 8px 10px;
      font-size: 14px;
      flex: none;
    }
  </style>
</head>
<body>
  
  <%- include('../partials/nav') %>

  <div class="container">
    <h2>Edit Home</h2>
    <form action="/host/edits" method="POST" enctype="multipart/form-data">
      
      <input type="hidden" name="id" value="<%= home.id %>">

      <label for="title">Home Title</label>
      <input type="text" id="title" name="title" value="<%= home.house_name %>" required>

      <label for="location">Location</label>
      <input type="text" id="location" name="location" value="<%= home.location %>" required>

      <label for="price">Price per Night</label>
      <input type="number" id="price" name="price" value="<%= home.price %>" required>

      <label for="rooms">Number of Rooms</label>
      <input type="number" id="rooms" name="rooms" value="<%= home.rooms %>" required>

      <label for="description">Description</label>
      <textarea id="description" name="description" required><%= home.description %></textarea>

      <label for="images">Add Images</label>
      <input type="file" multiple="multiple" accept="image/*" id="images" name="images[]">



      <div class="button-group">
        <button type="submit" class="btn btn-apply">Apply</button>
        <a href="/host/homeslist" class="btn btn-cancel">Cancel</a>
      </div>
    </form>
    <% if (home.image_records && home.image_records.length > 0) { %>
      <div class="image-list">
        <% home.image_records.forEach(image => { %>
          <div class="image-row">
            <img src="<%= image.image_url %>" alt="<%= home.house_name %>" loading="lazy">
            <form action="/host/delete-image" method="POST">
              <input type="hidden" name="id" value="<%= image.id %>">
              <input type="hidden" name="home_id" value="<%= home.id %>">
              <button type="submit" class="btn btn-cancel btn-small">Delete</button>
            </form>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</body>
</html>
```

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= title %></title>
  <style>
    table {
      width: 90%;
      margin: 40px auto;
      border-collapse: collapse;
      background: #fff;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }
    th, td {
      padding: 15px;
      text-align: left;
      border-bottom: 1px solid #ddd;
    }
    tr:nth-child(even) {
      background: #f9f9f9;
    }
    th {
      background: #ff5a5f;
      color: #fff;
    }
    .btn {
      padding: 6px 12px;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      font-weight: bold;
      margin-right: 8px;
    }
    .btn-details {
      background: #007bff;
      color: #fff;
    }
    .btn-details:hover {
      background: #3399ff;
    }
    .btn-remove {
      background: #ff5a5f;
      color: #fff;
    }
    .btn-remove:hover {
      background: #ff7e82;
    }
  </style>
</head>
<body>
  <%- include('../partials/nav') %>

  <div class="container">
    <h1>🏠 Hosted Homes</h1>

    <% if (house && house.length > 0) { %>
      <table>
        <thead>
          <tr>
            <th>House</th>
            <th>Location</th>
            <th>Price</th>
            <th>Rooms</th>
            <th>Rating</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% house.forEach(homes => { %>
            <tr>
              <td><%= homes.house_name %></td>
              <td><%= homes.location %></td>
              <td>$<%= homes.price %></td>
              <td><%= homes.rooms %></td>
              <td><%= homes.rating %></td>
              <td>
                <a href="/host/edit/<%= homes.id %>" class="btn btn-details">Edit</a>
                <form action="/host/remove-home" method="POST" style="display:inline;">
                  <input type="hidden" name="id" value="<%= homes.id %>">
                  <button type="submit" class="btn btn-remove">Remove</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } else { %>
      <p>No homes hosted yet.</p>
    <% } %>
  </div>
</body>
</html>

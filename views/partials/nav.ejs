<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%=title%></title>
  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #f7f7f7;
    }
    nav {
      background: linear-gradient(90deg, #ff5a5f, #ff7e82);
      padding: 15px 30px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      box-shadow: 0 2px 8px rgba(0,0,0,0.15);
    }
    nav h1 {
      color: #fff;
      margin: 0;
      font-size: 1.5rem;
      letter-spacing: 1px;
    }
    nav ul {
      list-style: none;
      display: flex;
      margin: 0;
      padding: 0;
      gap: 25px;
    }
    nav ul li a {
      color: #fff;
      text-decoration: none;
      font-weight: bold;
      transition: color 0.3s ease, transform 0.2s ease;
    }
    nav ul li a:hover {
      color: #ffe0e2;
      transform: scale(1.05);
    }
    .container {
      padding: 40px;
      text-align: center;
    }
    .container h2 {
      margin-bottom: 20px;
    }
    .homes {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 20px;
    }
    .home-card {
      background: #fff;
      padding: 20px;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }
  </style>
</head>
<body>
  <nav>
    <h1>Airbnb</h1>
    <ul>
      <li><a href="/">🏠 Home</a></li>
      <% if (locals.isLoggedIn) { %>
        <li><a href="/host/add-home">➕ Add Home</a></li>
        <li><a href="/fav">❤️ Favourites</a></li>
        <li><a href="/store/bookings">📅 Bookings</a></li>
        <li><a href="/host/homeslist">🏠 Host Homes</a></li>
        <li><a href="/auth/logout">🚪 Logout</a></li>
      <% } else { %>
        <li><a href="/auth/login">🔑 Log In</a></li>
        <li><a href="/auth/sign-up">📝 Sign Up</a></li>
      <% } %>
    </ul>
  </nav>

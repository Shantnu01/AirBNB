<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= title %></title>
  <style>
    :root {
      --radius: 0.625rem;
      --background: #ffffff;
      --foreground: #222222;
      --card: #ffffff;
      --card-foreground: #222222;
      --popover: #ffffff;
      --popover-foreground: #222222;
      --primary: #ff385c;
      --primary-foreground: #ffffff;
      --secondary: #ffffff;
      --secondary-foreground: #222222;
      --muted: #ffffff;
      --muted-foreground: #6a6a6a;
      --accent: #ff385c;
      --accent-foreground: #ffffff;
      --destructive: #e01e2c;
      --destructive-foreground: #ffffff;
      --border: #e5e5e5;
      --input: #e5e5e5;
      --ring: #ff385c;
    }
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: var(--background);
      color: var(--foreground);
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
    }
    .auth-container {
      background: var(--card);
      padding: 40px;
      border-radius: var(--radius);
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
      width: 360px;
      border: 1px solid var(--border);
      box-sizing: border-box;
    }
    h2 {
      margin: 0 0 8px 0;
      font-weight: 800;
      color: var(--foreground);
      text-align: center;
    }
    p {
      color: var(--muted-foreground);
      text-align: center;
      margin: 0 0 24px 0;
      font-size: 0.9rem;
    }
    label {
      display: block;
      margin-bottom: 6px;
      font-weight: bold;
      color: var(--foreground);
      font-size: 0.9rem;
    }
    input {
      width: 100%;
      padding: 10px;
      margin-bottom: 20px;
      border: 1px solid var(--input);
      border-radius: var(--radius);
      box-sizing: border-box;
      font-size: 0.95rem;
      text-align: center;
      letter-spacing: 4px;
    }
    input:focus {
      border-color: var(--ring);
      outline: none;
    }
    .btn-submit {
      width: 100%;
      padding: 12px;
      background: var(--primary);
      color: var(--primary-foreground);
      border: none;
      border-radius: var(--radius);
      font-size: 1rem;
      font-weight: bold;
      cursor: pointer;
      transition: background 0.15s ease;
      margin-bottom: 12px;
    }
    .btn-submit:hover {
      background: var(--destructive);
    }
    .btn-back {
      display: block;
      width: 100%;
      padding: 12px;
      background: var(--secondary);
      color: var(--secondary-foreground);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      font-size: 1rem;
      font-weight: bold;
      cursor: pointer;
      text-align: center;
      text-decoration: none;
      box-sizing: border-box;
      transition: background 0.15s ease, border-color 0.15s ease;
    }
    .btn-back:hover {
      background: var(--muted);
      border-color: var(--ring);
    }
    .switch-link {
      display: block;
      text-align: center;
      margin-top: 16px;
      font-size: 0.85rem;
      color: var(--muted-foreground);
    }
    .switch-link a {
      color: var(--primary);
      text-decoration: none;
      font-weight: bold;
    }
    .switch-link a:hover {
      text-decoration: underline;
    }
  </style>
</head>
<body>
  <div class="auth-container">
    <h2>OTP Verification</h2>
    <p>Please enter the 6-digit OTP sent to your email.</p>
    
    <form action="/auth/verify-otp" method="POST">
      <label for="otp">Enter OTP</label>
      <input type="text" id="otp" name="otp" placeholder="••••••" maxlength="6" pattern="[0-9]{6}" required autocomplete="one-time-code">

      <button type="submit" class="btn-submit">Verify & Submit</button>
      <a href="/auth/sign-up" class="btn-back">← Back to Sign Up</a>
    </form>

    <div class="switch-link">
      Didn't receive code? <a href="/auth/sign-up">Resend OTP</a>
    </div>
  </div>
</body>
</html>

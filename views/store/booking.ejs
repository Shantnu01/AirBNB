<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= title %></title>
  <style>
    table {
      width: 90%;
      margin: 40px auto;
      border-collapse: collapse;
      background: var(--card);
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
    }
    th, td {
      padding: 15px;
      text-align: left;
      border-bottom: 1px solid var(--border);
    }
    tr:nth-child(even) {
      background: var(--muted);
    }
    th {
      background: var(--primary);
      color: var(--primary-foreground);
    }
    .btn {
      padding: 6px 12px;
      border: none;
      border-radius: var(--radius);
      cursor: pointer;
      font-weight: bold;
      margin-right: 8px;
    }
    .btn-details {
      background: var(--secondary);
      color: var(--secondary-foreground);
      border: 1px solid var(--border);
    }
    .btn-details:hover {
      background: var(--muted);
    }
    .btn-cancel {
      background: var(--destructive);
      color: var(--destructive-foreground);
    }
    .btn-cancel:hover {
      background: var(--primary);
    }
  </style>
</head>
<body>
  <%- include('../partials/nav') %>
  <%
    const formatBookingDate = (value) => {
      if (!value) return '';

      const date = new Date(value);
      if (Number.isNaN(date.getTime())) return '';

      return date.toLocaleDateString('en-IN', {
        weekday: 'long',
        day: '2-digit',
        month: 'long',
        year: 'numeric'
      });
    };
  %>

  <div class="container">
    <h1>📅 My Bookings</h1>

    <% if (bookings && bookings.length > 0) { %>
      <table>
        <thead>
          <tr>
            <th>House</th>
            <th>Location</th>
            <th>Price</th>
            <th>Booked On</th>
            <th>Check-In</th>
            <th>Check-Out</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% bookings.forEach(booking => { %>
            <tr>
              <td><%= booking.house_name %></td>
              <td><%= booking.location %></td>
              <td>&#8377;<%= booking.price %></td>
              <td><%= formatBookingDate(booking.booked_on) %></td>
              <td><%= formatBookingDate(booking.date_of_booking) %></td>
              <td><%= formatBookingDate(booking.check_out) %></td>
              <td>
                <a href="/details/<%= booking.house_id %>" class="btn btn-details">Details</a>
                <form action="/store/cancel-booking" method="POST" style="display:inline;">
                  <input type="hidden" name="id" value="<%= booking.id %>">
                  <button type="submit" class="btn btn-cancel">Cancel</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } else { %>
      <p>You don’t have any bookings yet.</p>
    <% } %>
  </div>
</body>
</html>

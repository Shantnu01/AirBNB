<%- include('../partials/nav') %>

<%
  const detailImages = [];
  const addDetailImage = (src) => {
    if (src && !detailImages.includes(src)) {
      detailImages.push(src);
    }
  };
  addDetailImage(home.image);
  if (Array.isArray(home.images)) {
    home.images.forEach(addDetailImage);
  } else if (typeof home.images === 'string') {
    home.images.split(',').map((src) => src.trim()).forEach(addDetailImage);
  }
  [
    home.image2,
    home.image3,
    home.image4,
    home.image5,
    home.image_2,
    home.image_3,
    home.image_4,
    home.image_5
  ].forEach(addDetailImage);
%>

<div class="details-container">
  <div class="details-card">
    <div class="details-grid">
      <!-- Left side: Image -->
      <div class="details-image-section">
        <img src="<%= home.image %>" alt="<%= home.house_name %>" class="details-img" loading="lazy">
      </div>

      <!-- Right side: Content -->
      <div class="details-info-section">
        <div class="details-header">
          <span class="details-badge">Verified Property</span>
          <% if (home.rating) { %>
            <span class="details-rating">★ <%= home.rating %></span>
          <% } else { %>
            <span class="details-rating new-badge">No reviews yet</span>
          <% } %>
        </div>

        <h1 class="details-title"><%= home.house_name %></h1>
        <p class="details-location">📍 <%= home.location %></p>
        
        <div class="details-specs">
          <div class="spec-item">
            <span class="spec-icon">🛏️</span>
            <div>
              <strong><%= home.rooms %> Rooms</strong>
              <small>Spacious layout</small>
            </div>
          </div>
          <div class="spec-item">
            <span class="spec-icon">💵</span>
            <div>
              <strong>&#8377;<%= home.price %> / night</strong>
              <small>Best rate guarantee</small>
            </div>
          </div>
        </div>

        <div class="details-actions">
          <button class="book-now-btn">Book This Home</button>
          <a href="/" class="back-btn">Back to Homes</a>
        </div>
      </div>
    </div>
  </div>

  <div class="details-gallery">
    <h2>More Photos</h2>
    <div class="gallery-grid">
      <% detailImages.forEach((image, index) => { %>
        <img src="<%= image %>" alt="<%= home.house_name %> photo <%= index + 1 %>" class="gallery-img" loading="lazy">
      <% }) %>
    </div>
  </div>
</div>

<style>
  .details-container {
    max-width: 1000px;
    margin: 40px auto;
    padding: 0 20px;
  }

  .details-card {
    background: var(--card);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.06);
    border: 1px solid var(--border);
  }

  .details-grid {
    display: grid;
    grid-template-columns: 1fr;
  }

  @media (min-width: 768px) {
    .details-grid {
      grid-template-columns: 1.1fr 1fr;
    }
  }

  /* Image styling */
  .details-image-section {
    position: relative;
    width: 100%;
    aspect-ratio: 4/3;
    background: var(--input);
  }

  @media (min-width: 768px) {
    .details-image-section {
      height: 100%;
      aspect-ratio: auto;
      min-height: 380px;
    }
  }

  .details-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Info Section */
  .details-info-section {
    padding: 24px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .details-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
  }

  .details-badge {
    background: var(--secondary);
    color: var(--primary);
    font-weight: 700;
    font-size: 0.75rem;
    padding: 3px 8px;
    border-radius: 20px;
    border: 1.5px solid var(--primary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .details-rating {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--foreground);
    background: var(--muted);
    padding: 3px 8px;
    border-radius: 6px;
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
  }

  .new-badge {
    background: var(--secondary);
    color: var(--primary);
    border-color: var(--primary);
  }

  .details-title {
    font-size: 1.5rem;
    color: var(--foreground);
    margin: 0 0 6px 0;
    font-weight: 800;
  }

  .details-location {
    font-size: 0.95rem;
    color: var(--muted-foreground);
    margin: 0 0 20px 0;
  }

  /* Specs list */
  .details-specs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: 24px;
    padding: 16px 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .spec-item {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .spec-icon {
    font-size: 1.6rem;
  }

  .spec-item div {
    display: flex;
    flex-direction: column;
  }

  .spec-item strong {
    font-size: 0.9rem;
    color: var(--foreground);
  }

  .spec-item small {
    font-size: 0.75rem;
    color: var(--muted-foreground);
  }

  /* Action Buttons */
  .details-actions {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .book-now-btn {
    padding: 10px;
    background: var(--primary);
    color: var(--primary-foreground);
    border: none;
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: bold;
    cursor: pointer;
    transition: background 0.15s ease, transform 0.1s ease;
    box-shadow: 0 3px 10px rgba(255, 56, 92, 0.25);
  }

  .book-now-btn:hover {
    background: var(--destructive);
    transform: translateY(-1px);
  }

  .book-now-btn:active {
    transform: translateY(1px);
  }

  .back-btn {
    text-align: center;
    padding: 9px;
    background: var(--secondary);
    color: var(--secondary-foreground);
    border-radius: 8px;
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: bold;
    border: 1px solid var(--border);
    transition: background 0.15s ease, color 0.15s ease;
  }

  .back-btn:hover {
    background: var(--muted);
    color: var(--foreground);
  }

  .details-gallery {
    margin-top: 28px;
  }

  .details-gallery h2 {
    color: var(--foreground);
    font-size: 1.25rem;
    margin: 0 0 14px 0;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(1, minmax(0, 1fr));
    gap: 14px;
    margin-bottom: 40px;
  }

  @media (min-width: 640px) {
    .gallery-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 960px) {
    .gallery-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .gallery-img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: var(--input);
  }
</style>

</body>
</html>
